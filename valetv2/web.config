<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Compressão estática e dinâmica -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- Headers de segurança -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
      </customHeaders>
    </httpProtocol>

    <!-- Cache para assets estáticos (1 ano — Angular usa content hash) -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- 1. Proxy reverso: /api/* → backend Node.js na porta 3000 -->
        <rule name="API Proxy" stopProcessing="true">
          <match url="^api/v1/(.*)" />
          <action type="Rewrite" url="http://localhost:3000/api/v1/{R:1}" />
        </rule>

        <!-- 2. Proxy: endpoints legados (sem /api/) → backend -->
        <rule name="Legacy API Proxy" stopProcessing="true">
          <match url="^(authorizeValet|authorizeUser|valetVerify|userVerify|createTicket|user|qrcode|plateCheck|exit|setupValet|whitelist|blacklist|valets|occupancy|reports|pricing|alerts|sync|totem|health|ready)(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}{R:2}" />
        </rule>

        <!-- 3. Angular SPA fallback: qualquer rota → index.html -->
        <rule name="Angular SPA" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
