rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Manobristas: leitura para login, escrita bloqueada
    match /valets/{valetId} {
      allow read: if true;
      allow write: if false;
    }

    // Tickets: leitura e escrita aberta (app interno)
    match /tickets/{ticketId} {
      allow read, write: if true;
    }

    // Contador de tickets
    match /counters/{counterId} {
      allow read, write: if true;
    }
  }
}
