# ============================================
# 2M Parking API — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Banco de Dados (SQL Server) ---
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=MParking
DB_USER=mparking_app
DB_PASSWORD=SUA_SENHA_AQUI

# --- Autenticação JWT ---
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_ALEATORIA

# --- Setup (criação de valets via /setupValet) ---
SETUP_KEY=TROQUE_POR_UMA_CHAVE_SEGURA

# --- CORS (origens permitidas, separadas por vírgula) ---
CORS_ORIGINS=http://localhost:4200

# --- HTTPS (opcional, modo dual HTTP/HTTPS) ---
# HTTPS_ENABLED=true
# HTTPS_KEY=/caminho/para/privkey.pem
# HTTPS_CERT=/caminho/para/fullchain.pem

# --- Alertas Webhook ---
# Configurável via endpoint PATCH /alerts/config (admin)
# Defaults armazenados na tabela system_config

# --- Logging ---
# Níveis: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# --- Mercado Pago (PIX + Cartão) ---
# Obtenha em https://www.mercadopago.com.br/developers/panel/app
# Sem MP_ACCESS_TOKEN o sistema funciona em modo SANDBOX MOCK
# MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MP_WEBHOOK_SECRET=sua_chave_webhook_secreta
