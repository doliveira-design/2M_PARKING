# ============================================
# 2M Parking — Variáveis Docker Compose
# ============================================
# Copie para .env.docker e preencha os valores.
# Uso: docker-compose --env-file .env.docker up --build
# NUNCA commite o arquivo .env.docker no repositório.

# Senha SA do SQL Server (mínimo 8 chars, maiúscula+minúscula+número/símbolo)
SA_PASSWORD=TROQUE_POR_SENHA_FORTE

# Chave secreta para assinatura JWT (mínimo 32 chars aleatórios)
JWT_SECRET=TROQUE_POR_CHAVE_SECRETA_ALEATORIA

# Chave para endpoint de setup
SETUP_KEY=TROQUE_POR_CHAVE_SETUP

# Origens CORS permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost,http://localhost:80

# Nível de log (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
